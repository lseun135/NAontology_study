    skos:inScheme nam1:RepresentationTypeScheme ;
    skos:broader nam1:Visual ;
    skos:prefLabel "아날로그 시각"@ko, "Analogue Visual"@en ;
    skos:scopeNote "스케치·인화 사진 등 물리적 정지 이미지 기록 방식"@ko .

nam1:DigitalVisual a rico:RepresentationType, skos:Concept ;
    skos:inScheme nam1:RepresentationTypeScheme ;
    skos:broader nam1:Visual ;
    skos:prefLabel "디지털 시각"@ko, "Digital Visual"@en ;
    skos:scopeNote "디지털 방식으로 생성·저장된 정지 이미지 기록 방식. 재생 기기 필요"@ko .

### Video 하위
nam1:AnalogueVideo a rico:RepresentationType, skos:Concept ;
    skos:inScheme nam1:RepresentationTypeScheme ;
    skos:broader nam1:Video ;
    skos:prefLabel "아날로그 영상"@ko, "Analogue Video"@en ;
    skos:scopeNote "VHS·필름 등 아날로그 동영상 기록 방식. 재생 기기 필요"@ko .

nam1:DigitalVideo a rico:RepresentationType, skos:Concept ;
    skos:inScheme nam1:RepresentationTypeScheme ;
    skos:broader nam1:Video ;
    skos:prefLabel "디지털 영상"@ko, "Digital Video"@en ;
    skos:scopeNote "디지털 방식으로 생성·저장된 동영상 기록 방식. 재생 기기 필요"@ko .

