@prefix nam1: <https://lseun135.github.io/NAontology_study/m1-record#> .
@prefix nam2: <https://lseun135.github.io/NAontology_study/m2-person#> .
@prefix nam3: <https://lseun135.github.io/NAontology_study/m3-content#> .
@prefix nadat1: <https://lseun135.github.io/NAontology_study/resource/d1-record#> .
@prefix nadat2: <https://lseun135.github.io/NAontology_study/resource/d2-person#> .
@prefix nadat3: <https://lseun135.github.io/NAontology_study/resource/d3-content#> .

@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix bf: <https://id.loc.gov/ontologies/bibframe/> .
@prefix bio: <http://purl.org/vocab/bio/0.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix gn:     <https://www.geonames.org/ontology#> .
@prefix opengov: <http://www.w3.org/ns/opengov#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rico: <https://www.ica.org/standards/RiC/ontology#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <https://www.w3.org/2004/02/skos/core#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .



@base    <https://lseun135.github.io/NAontology_study/m1-record#> .


<https://lseun135.github.io/NAontology_study/m1-record> a owl:Ontology ;
        owl:imports <https://www.ica.org/standards/RiC/ontology/1.1> .


# Class
## A 분류체계: 국회 회의록·의안기록물
nam1:A rdf:type rico:RecordSet ;
       rico:includesOrIncluded nam1:A-MIN , nam1:A-BIL ;
       rico:classification "A" ;
       rico:generalDescription "국회 대수(代數)별로 생산되는 회의록·의안기록물"@ko ;
       rico:name "국회 회의록·의안기록물"@ko ;
       rdfs:label "[A] 국회 회의록·의안기록물"@ko .

nam1:A-MIN a rico:RecordSet ;
    rico:name "회의록"@ko ;
    rico:identifier "A-MIN" ;
    rdfs:label "[A-MIN] 회의록"@ko ;
    rico:includesOrIncluded nam1:A-MIN-021 .

nam1:A-BIL a rico:RecordSet ;
    rico:name "의안기록물"@ko ;
    rico:identifier "A-BIL" ;
    rdfs:label "[A-BIL] 의안기록물"@ko .


## B 분류체계: 생산·이관기록물
nam1:B rdf:type rico:RecordSet ;
       rico:classification "B" ;
       rico:generalDescription "연도별 국회 조직(소속기관 등) 생산 기록물"@ko ;
       rico:name "생산·이관기록물"@ko ;
       rdfs:label "[B] 생산·이관기록물"@ko .


## C 분류체계: 수집기록물
nam1:C rdf:type rico:RecordSet ;
       rico:includesOrIncluded nam1:C-PER , nam1:C-ORG ;
       rico:classification "C" ;
       rico:generalDescription "개인(의원), 단체(정당) 등으로부터 수집한 기록물"@ko ;
       rico:name "수집기록물"@ko ;
       rdfs:label "[C] 수집기록물"@ko .

nam1:C-PER a rico:RecordSet ;
    rico:name "개인(의원) 수집기록물"@ko ;
    rico:identifier "C-PER" ;
    rdfs:label "[C-PER] 개인(의원) 수집기록물"@ko .

nam1:C-ORG a rico:RecordSet ;
    rico:name "단체(정당) 수집기록물"@ko ;
    rico:identifier "C-ORG" ;
    rdfs:label "[C-ORG] 단체(정당) 수집기록물"@ko .


## foaf:Person ⊑ rico:Person ⊑ rico:Agent ⊑ foaf:Agent
rico:Agent rdfs:subClassOf foaf:Agent ; 
        rdfs:comment "이 모델에서는 rico:Agent를 foaf:Agent의 하위 개념으로 해석한다.(FOAF는 일반적 행위자, RiC는 기록관리 맥락에 영향을 주는 행위자)"@ko .

### FOAF/ORG → RiC 브리지 (d2의 개체를 d1에서 RiC로 자동 승격) / 추론기(reasoner)가 켜진 환경에서만 동작
foaf:Person rdfs:subClassOf rico:Person ;
  rdfs:comment "d2에서 foaf:Person으로 선언된 개체는 nadat1에서 rico:Person(=rico:Agent)으로 자동 해석된다."@ko .

## org:FormalOrganization, org:OrganizationalUnit ⊑ rico:CorporateBody ⊑ rico:Group ⊑ rico:Agent ⊑ foaf:Agent
### 조직: ORG의 공식/내부 조직만 CorporateBody로 승격 (org:Organization 전체를 일괄 매핑하지 않는 이유는 범위 과대추론을 피하기 위함)
org:FormalOrganization  rdfs:subClassOf rico:CorporateBody ;
  rdfs:comment "nadat2에서 FormalOrganization, org:OrganizationalUnit으로 선언된 개체는 nadat1에서 rico:CorporateBody로 자동 해석된다"@ko .

org:OrganizationalUnit  rdfs:subClassOf rico:CorporateBody ;
  rdfs:comment "nadat2에서 OrganizationalUnit으로 선언된 개체는 nadat1에서 rico:CorporateBody로 본다."@ko .

rico:hasOrHadMember rdfs:seeAlso org:hasMember ;
        rdfs:comment "m1(record)에서 기록 참여자 관계를 표현하며, m2(person)의 조직적 구성 관계(org:hasMember)와 연동됨."@ko .


### 내용 단위 연결 속성 (RecordResource → ContentUnit)
nam1:hasContentUnit a owl:ObjectProperty ;
    rdfs:label "has content unit"@en ;
    rdfs:label "내용단위를 가진다"@ko ;
    rdfs:comment "기록물(RecordResource)이 포함하고 있는 내용 단위(ContentUnit)를 연결하기 위한 속성."@ko ;
    rdfs:domain rico:RecordResource ;
    rdfs:range  nam3:ContentUnit ;
    rdfs:subPropertyOf dcterms:hasPart .

### dcterms:subject를 "documents ∘ hasAgendaItem"의 체인 결과로도 쓰게 함
dcterms:subject a owl:ObjectProperty ;
        owl:propertyChainAxiom ( rico:documents nam3:hasAgendaItem ) .

[ owl:inverseOf nam1:hasContentUnit ] rdfs:subPropertyOf dcterms:source .







# individuals
## RuleType
nam1:RuleTypeScheme a skos:ConceptScheme ;
        skos:hasTopConcept nam1:LegalNorm, nam1:Standard, nam1:Policy, nam1:SocialNorm ;  
        skos:prefLabel "규칙 유형 통제어"@ko, "Rule Type Controlled Vocabulary"@en ;
        dcterms:description "행위자의 존재·활동·책임을 규율하는 규칙의 유형을 기술하기 위한 개념체계"@ko .

nam1:LegalNorm a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:topConceptOf nam1:RuleTypeScheme ;
        skos:prefLabel "법적 규범"@ko ;
        skos:scopeNote "법률·명령·자치법규·행정규칙·기관규칙 등을 포함하는 법령체계 기반 규범"@ko ;
        skos:editorialNote "LegalNorm 계층은 대한민국 헌법(제6조 제1항, 제75조, 제95조), 
「법령 등 공포에 관한 법률」 제10조(법령 번호 부여 대상으로서 법률·대통령령·총리령·부령 열거), 
「법제업무 운영규정」(행정규칙: 훈령·예규·고시 등)에 근거하여 구성함."@ko .

nam1:Standard a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:topConceptOf nam1:RuleTypeScheme ;
        skos:prefLabel "표준"@ko ;
        skos:scopeNote "국제·국가·부처·업계 등 기술/전문 표준"@ko ;
        skos:editorialNote "국가기술표준원의 표준의 영역에 따른 분류를 근거로 하위계층을 구성함."@ko .

nam1:Policy a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:topConceptOf nam1:RuleTypeScheme ;
        skos:prefLabel "정책"@ko ;
        skos:editorialNote "법적 구속력의 유무와 제정 주체에 따라 구분한 로컬 통제어."@ko .

nam1:SocialNorm a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:topConceptOf nam1:RuleTypeScheme ;
        skos:prefLabel "사회적 규범"@ko ;
        skos:editorialNote "법적 구속력의 유무와 제정 주체에 따라 구분한 로컬 통제어."@ko .

### LegalNorm 하위
nam1:Legislation a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:LegalNorm ;
        skos:prefLabel "법령"@ko .

nam1:AdministrativeRule a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:LegalNorm ;
        skos:altLabel "행정규칙"@ko ;
        skos:prefLabel "행정규칙(훈령·예규·고시·공고·지시·규정 등)"@ko .

nam1:NationalInstitutionRule a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:LegalNorm ;
        skos:prefLabel "국가기관 규칙(국회규칙 등)"@ko .

nam1:Treaty a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:LegalNorm ;
        skos:editorialNote "헌법 제6조 제1항을 근거로 구성함."@ko ;
        skos:prefLabel "조약"@ko .

### 법령 하위 세분
nam1:Constitution a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:Legislation ;
        skos:prefLabel "헌법"@ko .

nam1:Act a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:Legislation ;
        skos:prefLabel "법률"@ko .

nam1:SubordinateLegislation a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:Legislation ;
        skos:prefLabel "하위법령(시행령·시행규칙 등)"@ko .

nam1:PresidentialDecree a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:SubordinateLegislation ;
        skos:prefLabel "대통령령(시행령)"@ko ;
        skos:altLabel "시행령"@ko, "대통령령"@ko .

nam1:PrimeMinisterialOrdinance a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:SubordinateLegislation ;
        skos:prefLabel "총리령(시행규칙)"@ko ;
        skos:altLabel "시행규칙"@ko, "총리령"@ko ;
        skos:scopeNote "동일 표기 ‘시행규칙’이 부령과 중복될 수 있어 발령주체(총리/각 부 장관)로 구분."@ko .

nam1:MinisterialOrdinance a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:SubordinateLegislation ;
        skos:prefLabel "부령(시행규칙)"@ko ;
        skos:altLabel "시행규칙"@ko, "부령"@ko ;
        skos:scopeNote "동일 표기 ‘시행규칙’이 총리령과 중복될 수 있어 발령주체(총리/각 부 장관)로 구분."@ko .

### 표준(Standard) 하위
nam1:InternationalStandard a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:Standard ;
        skos:prefLabel "국제표준"@ko ;
        skos:altLabel "ISO 표준"@ko, "국제표준화기구 표준"@ko ;
        skos:scopeNote "ISO(국제표준화기구)·IEC·ITU 등 국제 협의체가 제정한 비구속적 합의 표준. 각국이 자국 표준으로 채택할 수 있음 (「국가표준기본법」 제3조 제2호)"@ko .

nam1:NationalStandard a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:Standard ;
        skos:prefLabel "국가표준"@ko ;
        skos:scopeNote "국가·정부·공공기관 등 법적 관할권을 가진 기관이 제정한 공식 표준(예: KS, JIS, FIPS 등)"@ko .

nam1:ProfessionalStandard a rico:RuleType, skos:Concept ;
        skos:inScheme nam1:RuleTypeScheme ;
        skos:broader nam1:Standard ;
        skos:prefLabel "전문표준"@ko ;
        skos:scopeNote "전문 단체나 학회·산업협회 등에서 합의로 제정한 자율적 표준(예: IEEE, W3C, IETF 등)"@ko .




## DocumentaryFormType
nam1:DocumentaryFormTypeScheme a skos:ConceptScheme ;
        skos:prefLabel "기록 양식 유형 통제어"@ko , "Documentary Form Type Controlled Vocabulary"@en ;
        dcterms:description "기록(Record) 또는 기록 부분(RecordPart)의 외재적·내재적 요소에 따른 기록 양식 유형을 기술하기 위한 개념체계"@ko .

nam1:Minutes a rico:DocumentaryFormType, skos:Concept ;
        skos:inScheme nam1:DocumentaryFormTypeScheme ;
        skos:prefLabel "회의록"@ko , "Minutes"@en .

nam1:Bill a rico:DocumentaryFormType, skos:Concept ;
        skos:inScheme nam1:DocumentaryFormTypeScheme ;
        skos:prefLabel "의안"@ko , "Bill"@en .

nam1:Law a rico:DocumentaryFormType, skos:Concept ;
        skos:inScheme nam1:DocumentaryFormTypeScheme ;
        skos:prefLabel "법률"@ko , "Law"@en .


## CarrierType
nam1:CarrierTypeScheme a skos:ConceptScheme ;
        skos:prefLabel "매체 유형 통제어"@ko, "Carrier Type Controlled Vocabulary"@en ;
        dcterms:description "사본·구현(instantiation)이 존재하는 물리적 매체의 유형을 기술하기 위한 개념체계"@ko ;
        dcterms:created "2025-10-23"^^xsd:date .

nam1:DigitalFile a rico:CarrierType, skos:Concept ;
        skos:inScheme nam1:CarrierTypeScheme ;
        skos:prefLabel "디지털파일"@ko, "Digital file"@en .

nam1:Paper a rico:CarrierType, skos:Concept ;
        skos:inScheme nam1:CarrierTypeScheme ;
        skos:prefLabel "종이"@ko, "Paper"@en .


### ProductionTechniqueType
nam1:ProductionTechniqueTypeScheme a skos:ConceptScheme ;
        skos:prefLabel "제작기법 유형 통제어"@ko, "Production Technique Type Controlled Vocabulary"@en ;
        dcterms:description "사본·구현(instantiation)에 정보를 표현하는 데 사용된 기법의 유형을 기술하기 위한 개념체계"@ko ;
        dcterms:created "2025-10-23"^^xsd:date .

nam1:Printing a rico:ProductionTechniqueType, skos:Concept ;
        skos:inScheme nam1:ProductionTechniqueTypeScheme ;
        skos:prefLabel "인쇄"@ko, "Printing"@en .

nam1:DigitalCreation a rico:ProductionTechniqueType, skos:Concept ;
        skos:inScheme nam1:ProductionTechniqueTypeScheme ;
        skos:prefLabel "전자적 생성"@ko, "Digital creation"@en .

nam1:Recording a rico:ProductionTechniqueType, skos:Concept ;
        skos:inScheme nam1:ProductionTechniqueTypeScheme ;
        skos:prefLabel "녹화"@ko, "Recording"@en .


## RepresentationType
nam1:RepresentationTypeScheme a skos:ConceptScheme ;
        skos:prefLabel "표현 유형 통제어"@ko, "Representation Type Controlled Vocabulary"@en ;
        dcterms:description "사본·유형(instantiation)의 콘텐츠 유형을 기록하는 방식의 유형을 기술하기 위한 개념체계."@ko ;
        dcterms:created "2025-10-23"^^xsd:date .

### 상위 개념
nam1:Textual a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:topConceptOf nam1:RepresentationTypeScheme ;
        skos:prefLabel "문자 기반"@ko, "Textual"@en ;
        skos:scopeNote "문자로 기록된 방식. 물리적 문자 기록과 전자적 문자 기록을 모두 포함."@ko .

nam1:Visual a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:topConceptOf nam1:RepresentationTypeScheme ;
        skos:prefLabel "시각"@ko, "Visual"@en ;
        skos:scopeNote "정지 이미지로 기록된 방식. 스케치·사진 등 포함. 동영상(Video)과 구분됨."@ko .

nam1:Video a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:topConceptOf nam1:RepresentationTypeScheme ;
        skos:prefLabel "영상"@ko, "Video"@en ;
        skos:scopeNote "연속 동영상으로 기록된 방식."@ko .

nam1:Audio a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:topConceptOf nam1:RepresentationTypeScheme ;
        skos:prefLabel "음향"@ko, "Audio"@en ;
        skos:scopeNote "음향으로 기록된 방식."@ko .

### Textual 하위
nam1:AnalogueTextual a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:broader nam1:Textual ;
        skos:prefLabel "아날로그 문자 기반"@ko, "Analogue textual"@en ;
        skos:scopeNote "필사·인쇄 등 물리적 문자 기록 방식."@ko .

nam1:DigitalTextual a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:broader nam1:Textual ;
        skos:prefLabel "디지털 문자 기반"@ko, "Digital textual"@en ;
        skos:scopeNote "전자적으로 생성·저장된 문자 기록 방식. 재생 기기 필요."@ko .

### Visual 하위
nam1:AnalogueVisual a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:broader nam1:Visual ;
        skos:prefLabel "아날로그 시각"@ko, "Analogue visual"@en ;
        skos:scopeNote "스케치·인화 사진 등 물리적 정지 이미지 기록 방식."@ko .

nam1:DigitalVisual a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:broader nam1:Visual ;
        skos:prefLabel "디지털 시각"@ko, "Digital visual"@en ;
        skos:scopeNote "디지털 방식으로 생성·저장된 정지 이미지 기록 방식. 재생 기기 필요."@ko .

### Video 하위
nam1:AnalogueVideo a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:broader nam1:Video ;
        skos:prefLabel "아날로그 영상"@ko, "Analogue video"@en ;
        skos:scopeNote "VHS·필름 등 아날로그 동영상 기록 방식. 재생 기기 필요."@ko .

nam1:DigitalVideo a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:broader nam1:Video ;
        skos:prefLabel "디지털 영상"@ko, "Digital video"@en ;
        skos:scopeNote "디지털 방식으로 생성·저장된 동영상 기록 방식. 재생 기기 필요."@ko .

### Audio 하위
nam1:AnalogueAudio a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:broader nam1:Audio ;
        skos:prefLabel "아날로그 음향"@ko, "Analogue audio"@en ;
        skos:scopeNote "LP·카세트테이프 등 아날로그 음향 기록 방식. 재생 기기 필요."@ko .

nam1:DigitalAudio a rico:RepresentationType, skos:Concept ;
        skos:inScheme nam1:RepresentationTypeScheme ;
        skos:broader nam1:Audio ;
        skos:prefLabel "디지털 음향"@ko, "Digital audio"@en ;
        skos:scopeNote "디지털 방식으로 생성·저장된 음향 기록 방식. 재생 기기 필요."@ko .


## DateType
nam1:DateTypeScheme a skos:ConceptScheme ;
        skos:prefLabel "날짜 유형 통제어"@ko, "Date Type Controlled Vocabulary"@en .

nam1:SingleDate a rico:DateType, skos:Concept ;
        skos:prefLabel "단일 날짜"@ko, "Single date"@en ;
        skos:inScheme nam1:DateTypeScheme ;
        skos:scopeNote "특정 시점을 나타내는 하나의 날짜."@ko .

nam1:DateRange a rico:DateType, skos:Concept ;
        skos:prefLabel "날짜 범위"@ko, "Date range"@en ;
        skos:inScheme nam1:DateTypeScheme ; 
        skos:scopeNote "시작과 끝이 있는 연속 구간을 나타내는 날짜."@ko .

nam1:DateSet a rico:DateType, skos:Concept ;
        skos:prefLabel "날짜 집합"@ko, "Date set"@en ;
        skos:inScheme nam1:DateTypeScheme ;
        skos:scopeNote "연속적이지 않은 둘 이상의 날짜로 구성된 집합."@ko .

nam1:Year a rico:DateType, skos:Concept ;
        skos:prefLabel "연도"@ko, "Year"@en ;
        skos:inScheme nam1:DateTypeScheme ;
        skos:scopeNote "연 단위로만 특정된 날짜."@ko .



## ContentType
nam1:ContentTypeScheme a skos:ConceptScheme ;
        skos:prefLabel "콘텐츠 유형 통제어"@ko, "Content Type Controlled Vocabulary"@en ;
        dcterms:description "기록(Record) 또는 기록 부분(RecordPart)의 정보가 표현되어 전달되는 형식의 유형을 기술하기 위한 개념체계"@ko .

nam1:Text a rico:ContentType, skos:Concept ;
        skos:inScheme nam1:ContentTypeScheme ;
        skos:topConceptOf nam1:ContentTypeScheme ;
        skos:prefLabel "텍스트"@ko, "Text"@en .

nam1:StillImage a rico:ContentType, skos:Concept ;
        skos:inScheme nam1:ContentTypeScheme ;
        skos:topConceptOf nam1:ContentTypeScheme ;
        skos:prefLabel "정지 이미지"@ko, "Still image"@en .

nam1:RecordedSpokenWord a rico:ContentType, skos:Concept ;
        skos:inScheme nam1:ContentTypeScheme ;
        skos:topConceptOf nam1:ContentTypeScheme ;
        skos:prefLabel "녹음 음성"@ko, "Recorded spoken word"@en .


## LegalStatus
nam1:LegalStatusScheme a skos:ConceptScheme ;
    skos:prefLabel "법적 지위 통제어"@ko, "Legal Status Controlled Vocabulary"@en ;
    dcterms:description "법에 의해 규정된 기록 자원 또는 행위자의 법적 지위를 기술하기 위한 개념체계"@ko .

nam1:PublicRecord a rico:LegalStatus, skos:Concept ;
        skos:prefLabel "공공기록물"@ko, "Public records"@en ;
        skos:topConceptOf nam1:LegalStatusScheme ;
        skos:inScheme nam1:LegalStatusScheme .


## Language
nam1:LanguageScheme a skos:ConceptScheme ;
        skos:prefLabel "언어 통제어"@ko, "Language Controlled Vocabulary"@en ;
        dcterms:description "기록 자원(RecordResource)에 표현되거나 행위자(Agent)가 사용하는 자연어를 기술하기 위한 개념체계"@ko ;
        skos:hasTopConcept nam1:lang-kor .

nam1:lang-kor a rico:Language, skos:Concept ;
        skos:prefLabel "한국어"@ko, "Korean"@en ;
        skos:notation "kor" ;
        skos:topConceptOf nam1:LanguageScheme ;
        skos:exactMatch <http://id.loc.gov/vocabulary/iso639-2/kor> ;
        skos:inScheme nam1:LanguageScheme .





## rico:EventType
nam1:EventTypeScheme rdf:type skos:ConceptScheme ;
        skos:prefLabel "국회 사건 유형 통제어"@ko, "NationalAssembly Event Types Controlled Vocabulary"@en ;
        skos:hasTopConcept nam1:Proceeding ;
        dcterms:description "국회에서 발생하는 사건(Event)의 유형을 기술하기 위한 개념체계. 본 논문에선 회의에 한정."@ko .

nam1:Proceeding rdf:type rico:EventType , skos:Concept ;
        skos:inScheme  nam1:EventTypeScheme ;
        skos:topConceptOf nam1:EventTypeScheme ;
        skos:prefLabel "회의"@ko, "Proceeding"@en .

nam1:PlenarySession rdf:type rico:EventType , skos:Concept ;
        skos:inScheme nam1:EventTypeScheme ;
        skos:broader  nam1:Proceeding ;
        skos:prefLabel "본회의"@ko , "Plenary session"@en ; 
        skos:altLabel  "국회 본회의"@ko .

nam1:StandingCommitteeMeeting rdf:type rico:EventType , skos:Concept ;
        skos:inScheme nam1:EventTypeScheme ;
        skos:broader  nam1:Proceeding ;
        skos:narrower nam1:StandingSubCommitteeMeeting ;
        skos:prefLabel "상임위원회 회의"@ko , "Standing committee meeting"@en .

nam1:SpecialCommitteeMeeting rdf:type rico:EventType , skos:Concept ;
        skos:inScheme nam1:EventTypeScheme ;
        skos:broader nam1:Proceeding ;
        skos:narrower nam1:SpecialSubCommitteeMeeting ;
        skos:prefLabel "특별위원회 회의"@ko , "Special committee meeting"@en .

nam1:StandingSubCommitteeMeeting rdf:type rico:EventType , skos:Concept ;
        skos:inScheme nam1:EventTypeScheme ; 
        skos:broader  nam1:StandingCommitteeMeeting ;
        skos:prefLabel "상임위-소위원회 회의"@ko , "Subcommittee meeting"@en .

nam1:SpecialSubCommitteeMeeting rdf:type rico:EventType , skos:Concept ;
        skos:inScheme nam1:EventTypeScheme ; 
        skos:broader  nam1:SpecialCommitteeMeeting ;
        skos:prefLabel "특별위-소위원회 회의"@ko , "Subcommittee meeting"@en .



# National Assembly Activity Types (Phase + Action)
nam1:ActivityTypeScheme a skos:ConceptScheme ;
        skos:prefLabel "국회 활동 유형 통제어"@ko, "NationalAssembly Activity Type Controlled Vocabulary"@en ;
        skos:hasTopConcept nam1:ProcedurePhase, nam1:ProcedureAction ;
        dcterms:description "국회의 활동(Activity). 본 연구에선 회의 절차(Phase/Action)를 기술하기 위한 개념체계. 패싯분류 방식으로 행위(Action)와 단계(Phase)를 조합하여 분류함."@ko .

## Top concepts
nam1:ProcedurePhase  a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:topConceptOf nam1:ActivityTypeScheme ;
        skos:prefLabel "절차 단계"@ko , "Procedure phase"@en .

nam1:ProcedureAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:topConceptOf nam1:ActivityTypeScheme ;
        skos:prefLabel "절차 행위"@ko , "Procedure action"@en .


### Phase 계열
nam1:InitiationPhase a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedurePhase ;
        skos:prefLabel "입안 단계"@ko , "Initiation phase"@en ;
        skos:scopeNote "법률안 발의·제출부터 소관 위원회 회부 이전까지의 단계."@ko .  

nam1:CommitteePhase a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedurePhase ;
        skos:prefLabel "위원회 단계"@ko , "Committee phase"@en ; 
        skos:scopeNote "법률안이 소관 상임위원회에 회부된 이후, 위원회에서의 심사와 관련된 절차를 포함."@ko .

nam1:LJCPhase a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedurePhase ;
        skos:prefLabel "법제사법위원회 단계"@ko , "Legislation and judiciary committee phase"@en ;
        skos:scopeNote "법제사법위원회에서 체계·자구 심사가 수행되는 단계. 상임위원회 심사 이후 본회의 상정 이전의 절차를 포함."@ko .

nam1:PlenaryPhase a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedurePhase ;
        skos:prefLabel "본회의 단계"@ko , "Plenary phase"@en ;
        skos:scopeNote "본회의에서 안건이 상정되어 심의·표결되는 절차를 포함."@ko .

nam1:PostPassagePhase a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedurePhase ;
        skos:prefLabel "사후 단계(정부·공포)"@ko , "Post-passage phase"@en ;
        skos:scopeNote "본회의 가결 이후 정부 이송, 대통령 서명 및 공포까지의 절차를 포함. 
국회 절차 종료 이후 행정부에서 이루어지는 단계."@ko .


### Action 계열
nam1:PriorAnnouncement a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:ProcedureAction ;
        skos:prefLabel "입법예고"@ko , "Prior Announcement of Legislation"@en ;
        skos:scopeNote "위원회 단계에서만 발생. 회부 이후 상정 이전에 위원장이 법률안의 입법 취지와 주요 내용을 공개하여 국민 의견을 수렴하는 행위."@ko .

nam1:Referral a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:ProcedureAction ;
        skos:prefLabel "회부"@ko , "Referral"@en ;
        skos:scopeNote "위원회 및 법사위 단계에서 발생. 국회의장이 법률안을 소관 위원회에 배정하거나, 소관 위원회 심사를 마친 법률안을 법사위에 넘기는 행위."@ko .

nam1:Presentation a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:ProcedureAction ;
        skos:prefLabel "상정"@ko , "Presentation"@en ;
        skos:scopeNote "위원회, 법사위, 본회의 단계에서 발생. 해당 회의체에서 법률안을 의사일정에 올려 심의를 개시하는 행위."@ko .

nam1:Report a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:ProcedureAction ;
        skos:prefLabel "보고"@ko , "Report"@en ;
        skos:scopeNote "법률안 심의 과정에서 이루어지는 보고 행위의 상위 개념. 발생 주체와 단계에 따라 전문위원 검토보고와 심사보고로 구분."@ko .

nam1:StaffReport a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:Report ;
        skos:prefLabel "전문위원 검토보고"@ko , "Report on Examination by Deputy Chief of Staff"@en ;
        skos:scopeNote "위원회 및 법사위 단계에서 발생. 전문위원이 법률안의 내용과 문제점을 검토하여 위원회에 보고하는 행위."@ko .

nam1:ChairReport a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:Report ;
        skos:prefLabel "심사보고"@ko , "Report on Committee Examination"@en ;
        skos:scopeNote "본회의 단계에서 발생. 소관위원회 위원장이 본회의에서 위원회 심사 경과와 결과를 보고하는 행위."@ko .

nam1:InterpellationDebate a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:ProcedureAction ;
        skos:prefLabel "질의 및 토론"@ko , "Interpellation and Debate"@en ;
        skos:scopeNote "법률안 심의 과정에서 이루어지는 질의·답변 및 토론 행위의 상위 개념. 질의, 대체토론, 찬반토론으로 구분."@ko .

nam1:Interpellation a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:InterpellationDebate ;
        skos:prefLabel "질의"@ko , "Interpellation"@en ;
        skos:scopeNote "본회의 단계에서 발생. 심사보고 이후 법률안에 대해 질문하고 답변을 듣는 행위."@ko .

nam1:GeneralDiscussion a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:InterpellationDebate ;
        skos:prefLabel "대체토론"@ko , "General Discussion"@en ;
        skos:scopeNote "위원회 및 법사위 단계에서 발생. 법률안 전체에 대한 문제점과 타당성을 논의하는 일반적 토론으로, 발의자에 대한 질의·답변을 포함."@ko .

nam1:ProConDebate a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:InterpellationDebate ;
        skos:prefLabel "찬반토론"@ko , "Arguments for and against"@en ;
        skos:scopeNote "위원회, 법사위, 본회의 단계에서 발생. 표결 전 법률안에 대한 찬성 및 반대 의견을 표명하는 행위."@ko .

nam1:Vote a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader nam1:ProcedureAction ;
        skos:prefLabel "표결"@ko , "Vote"@en ;
        skos:scopeNote "위원회, 법사위, 본회의 단계에서 발생. 법률안에 대한 최종 가부를 결정하는 행위. 재의 표결은 본회의 단계의 별도 경로로 처리되나 동일한 행위로 분류."@ko .
