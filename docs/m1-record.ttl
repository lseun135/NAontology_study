        skos:broader  nam1:ProcedureAction ;
        skos:prefLabel "안건 상정"@ko , "Agenda placement"@en ;
        skos:notation "agenda_placement" ;
        skos:scopeNote "안건을 공식적으로 심의 대상에 포함시키는 행위. 이후 심의나 표결이 이루어지기 위한 전제 절차."@ko .

nam1:BillPresentationAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction ;
        skos:prefLabel "제안설명"@ko , "Bill presentation"@en ;
        skos:notation "bill_presentation" .

nam1:DeliberationAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction ;
        skos:prefLabel "심의"@ko , "Deliberation"@en ;
        skos:altLabel "질의·토론"@ko , "Discussion"@en ;
        skos:notation "deliberation" .

nam1:VotingAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction ;
        skos:prefLabel "표결"@ko , "Voting"@en ;
        skos:notation "voting" .

nam1:ReportingAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction ;
        skos:prefLabel "보고"@ko , "Reporting"@en ;
        skos:notation "reporting" ;
        skos:scopeNote "위원회 또는 기관이 심사 결과나 검토 내용을 공식적으로 보고하는 행위. 이후 본회의 심의의 기초가 되는 정보를 제공함."@ko .

nam1:AdjournmentAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction ;
        skos:prefLabel "산회"@ko , "Adjournment"@en ;
        skos:notation "adjournment" ;
        skos:scopeNote "회의 종료를 나타내는 절차 행위."@ko .


### 입안(Action)
nam1:BillSubmissionAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction , nam1:InitiationPhase ;
        skos:prefLabel "법안 발의·제출"@ko , "Bill submission"@en ;
        skos:notation "init_bill_submission" ;
        skos:scopeNote "의원 발의, 정부 제출, 위원회안 제출 등을 포함."@ko .


### 위원회(Action)
nam1:CommitteeReferralAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction , nam1:CommitteePhase ;
        skos:prefLabel "상임위 회부"@ko , "Committee referral"@en ;
        skos:notation "committee_referral" ;
        skos:scopeNote "안건을 소관 상임위원회로 배분하는 절차 행위. 이후 위원회 단계의 심사가 개시되기 위한 전제 절차."@ko .

nam1:CommitteeAgendaPlacementAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction , nam1:CommitteePhase ;
        skos:prefLabel "상임위 상정"@ko , "Committee agenda placement"@en ;
        skos:notation "committee_agenda_placement" .

nam1:LegislativeNoticeAction  a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction , nam1:CommitteePhase ;
        skos:prefLabel "입법예고"@ko , "Legislative notice"@en ;
        skos:notation "committee_legislative_notice" ; 
        # 국회법 제82조의2

nam1:CommitteeReviewAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction , nam1:CommitteePhase ;
        skos:prefLabel "상임위 심사"@ko , "Committee review"@en ;
        skos:notation "committee_review" ;
        skos:scopeNote "상임위원회에서 안건의 내용과 적합성을 검토·심사하는 행위. 법률안에 대한 수정, 대안 제시, 심사 결과 도출 등을 포함할 수 있음"@ko .



#### 법제사법위원회(Action)
nam1:LJCReferralAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction , nam1:LJCPhase , nam1:CommitteeReferralAction ;
        skos:prefLabel "법제사법위원회 회부"@ko , "LJC referral"@en ;
        skos:altLabel  "체계·자구심사 회부"@ko ;
        skos:notation  "ljc_referral" ;
        skos:scopeNote "법제사법위원회로의 회부를 나타내는 절차 행위."@ko ;
        skos:editorialNote "CommitteeReferralAction의 특수화로 모델링하였으며, 별도 회의(Event) 없이도 발생 가능한 행위로 보았다."@ko .

nam1:LJCAgendaPlacementAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction , nam1:LJCPhase ;
        skos:prefLabel "법제사법위원회 상정"@ko , "LJC agenda placement"@en ;
        skos:notation "ljc_agenda_placement" .

nam1:LJCReviewAction a rico:ActivityType, skos:Concept ;
        skos:inScheme nam1:ActivityTypeScheme ;
        skos:broader  nam1:ProcedureAction , nam1:LJCPhase ;
        skos:prefLabel "법제사법위원회 심사(체계·자구)"@ko , "LJC review"@en ;
        skos:notation "ljc_review" ;
        skos:scopeNote "법제사법위원회에서 법률안의 체계와 자구를 중심으로 검토하는 심사 행위. 법적 형식과 정합성 검토에 초점."@ko .


#### 본회의(Action)
