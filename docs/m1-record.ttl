nam1:StillImage a rico:ContentType, skos:Concept ;
        skos:inScheme nam1:ContentTypeScheme ;
        skos:topConceptOf nam1:ContentTypeScheme ;
        skos:prefLabel "정지 이미지"@ko, "Still Image"@en .

nam1:RecordedSpokenWord a rico:ContentType, skos:Concept ;
        skos:inScheme nam1:ContentTypeScheme ;
